  author = {McLean, Alex and {Giovanni Fanfani} and {Ellen Harlizius--Kl\"uck}},
  year = 2018,
  journal = {Dancecult: Journal of Electronic Dance Music Culture},
  number = {1},
  pages = {5},
  publisher = {Griffith University},
  issn = {1947-5403},
  doi = {10.12801/1947-5403.2018.10.01.01},
  abstract = {This article hosts an interdisciplinary exploration of cyclic rhythmic structures, bringing together historical references to ground understanding of algorithmic electronic dance music, and in particular the algorave movement. The role of pattern in uniting dance, music and language is investigated in the ancient practice of weaving, in ancient Greek choral lyric, and contemporary live coding. In this context the TidalCycles environment is introduced, with some visual and audio examples. Cyclic metrical patterns in ancient Greek are then explored in detail, particularly the metrical transformations of Epiplok\=e. Finally, this jump between contemporary and ancient practice leads us to consider algorave itself as a Luddite movement, its proponents engaged in an unravelling of technology.},
