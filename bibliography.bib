  author = {Nesbitt, Nick},
  editor = {Hulse, Brian},
  year = 2010,
  publisher = {Routledge},
  abstract = {It is the contention of the editors and contributors of this volume that the work carried out by Gilles Deleuze, where rigorously applied, has the potential to cut through much of the intellectual sedimentation that has settled in the fields of music studies. Deleuze is a vigorous critic of the Western intellectual tradition, calling for a 'philosophy of difference', and, despite its ambitions, he is convinced that Western philosophy fails to truly grasp (or think) difference as such. It is argued that longstanding methods of conceptualizing music are vulnerable to Deleuze's critique. But, as Deleuze himself stresses, more important than merely critiquing established paradigms is developing ways to overcome them, and by using Deleuze's own concepts this collection aims to explore that possibility.},
