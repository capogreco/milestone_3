  shorttitle = {Ubiquitous {{Music Ecosystems}}},
  booktitle = {Ubiquitous {{Music}}},
  author = {Lazzarini, Victor and Keller, Dami{\'a}n and Pimenta, Marcelo and Timoney, Joseph},
