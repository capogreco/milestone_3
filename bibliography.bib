@incollection{FeelingAnalogueUsing2023,
  title = {Feeling {{Analogue}} : {{Using Modular Synthesizers}}, {{Designing Synthesis Communities}}},
  shorttitle = {Feeling {{Analogue}}},
  booktitle = {Shaping {{Sound}} and {{Society}}},
  year = 2023,
  month = sep,
  pages = {54--73},
  publisher = {Routledge},
  doi = {10.4324/9780367816070-5},
  urldate = {2026-04-06},
  abstract = {When Harald Bode nominally invented the modular synthesizer in 1958, it was not yet clear whether it was a musical instrument or a less-defined form of studio-sited audio technology. Much of the technology, from the interface design to the specific parts, was shared with equipment considered at the time to be technical but not essentially musical. Sixty years later, hardware modular synthesis is used not just for musical creation but for noise, sound art, foley, and data sonification/visualization. Through a study of the design and use of the Eurorack modular synthesis format, I will investigate questions concerning both the ontology of `the musical instrument' and the way we conceive of the building blocks of `musical sound'. While Western music theory assumes that music's smallest building blocks are pitches with measurable loudness and duration, occasionally accompanied by an amorphous `timbre' attribute, this conceptualization unravels when considering modular synthesizer-created music. The most distinctive so-called `timbral' features result from operations involving rhythmic timings ranging from submillisecond microtimings to several hour-long durations, while rhythmic effects or perceived pitches can be a byproduct of strategically combined nonpitched `timbres'. Instead, I propose a framework for understanding what is distinctive about modular synthesis that attends to three phenomena: the design (topological, aesthetic, interfacial) of modules, the user's kinesthetic and sensory experience of module interfaces and the kinds of operations users are expected to be able to do by using the module interfaces. This framework has additional benefits of moving beyond the flawed `analogue' versus `digital' distinction and exploring important underexamined aspects of musical digitization. Extending recent work in critical organology, I analyze the social lives of synthesizer modules in relation to their user communities. Rather than imposing a top-down taxonomic modular synthesis definition in the mode of Hornbostel--Sachs or its extensions, I derive taxonomic and ontological features from a grounded theory study conducted with modular synthesizer participants (makers, users, and social media `influencers') based in the US and Europe, supplemented with discourse analysis of modular synthesizer discussion happening at trade shows and online at modular synthesizer message forums. Through using this framework, I will show that the `analogue feel' of modular synthesis, in addition to resulting from a broader history of technological interface development, is constitutive both of the technologies and of the social lives of synthesizer users/designers.},
  langid = {english}
}

@book{fellStructureSynthesisAnatomy2021,
  title = {Structure and Synthesis: The Anatomy of Practice},
  shorttitle = {Structure and Synthesis},
  author = {Fell, Mark},
  year = 2021,
  publisher = {Urbanomic Media Ltd.},
  address = {Falmouth, United Kingdom},
  abstract = {In this extensive anthology, Mark Fell, a pioneering artist known for his sound installations and his musical work solo and as part of SND and Sensate Focus, assembles a collection of diverse materials charting his defiantly unorthodox thinking on time, structure, technology, and the relation between academic and popular electronic music. An amalgam of workbook and manifesto, featuring a collection of interleaved statements, diagrammatic scores, and instructional texts, Structure and Synthesis is a direct engagement with Fell's original thinking and his continual provocations in regard to "experimental" music. Alongside reflections on theory and practice, the volume includes exercises for dismantling musical expertise, habits, and intuitions, documenting Fell's explorations of the peripheries of rhythm, shape, and time in perception and performance. Long-term collaborator designer Joe Gilmore provides a striking graphic context for Fell's evolving thinking and the methods and structures he has developed through his solo and collaborative work.},
  collaborator = {Mackay, Robin and Gilmore, Joe},
  isbn = {978-1-913029-95-1},
  langid = {english},
  lccn = {781.648 F317},
  keywords = {Avant-garde (Music),Electronic music,Electronica (Music),Electronica (Musique),Musique experimentale}
}

@misc{finnIntroductionTimeSensitiveNetworking2022,
  title = {Introduction to {{Time-Sensitive Networking}}},
  author = {Finn, Norman},
  year = 2022,
  journal = {IEEE communications standards magazine},
  volume = {6},
  number = {4},
  pages = {8--13},
  publisher = {IEEE},
  issn = {2471-2825},
  doi = {10.1109/MCOMSTD.0004.2200046},
  abstract = {Since the year 2000, a number of companies and standards development organizations have been producing products and standards for Time-Sensitive Networking to support real-time applications that require zero packet loss due to buffer congestion, extremely low packet loss due to equipment failure, and guaranteed upper bounds on end-to-end latency. Often, a robust capability for time synchronization to less than 1 s is also required. These networks consist of specially-featured bridges that are interconnected using standard Ethernet links with standard MAC/PHY layers. Since the year 2012, this technology has advanced to the use of routers, as well as bridges, and features of interest to Time-Sensitive Net-working have been added to both Ethernet and wireless standards. Since the year 2018, TSN standardization has been expanding to include more queuing and pacing technologies, and to support new markets, such as industrial, automotive, aviation, and service provider applications.},
  langid = {english},
  keywords = {Bridges,Business enterprises}
}

